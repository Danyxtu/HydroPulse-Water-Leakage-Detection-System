MQTT_URL=wss://your-cluster.s1.eu.hivemq.cloud:8884/mqtt
MQTT_USERNAME=your_mqtt_username
MQTT_PASSWORD=your_mqtt_password

# Backward-compatible fallbacks currently used in this repository:
EXPO_PUBLIC_MQTT_URL=wss://your-cluster.s1.eu.hivemq.cloud:8884/mqtt
EXPO_PUBLIC_MQTT_USERNAME=your_mqtt_username
EXPO_PUBLIC_MQTT_PASSWORD=your_mqtt_password

# Either set DATABASE_URL directly...
DATABASE_URL=postgresql://postgres:password@127.0.0.1:5432/hydropulse?schema=public

# ...or provide DB_* values (DATABASE_URL will be built automatically)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=hydropulse